{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/weave-proof-envelope-v0.1.schema.json",
  "title": "WEAVE ProofEnvelope",
  "type": "object",
  "required": [
    "schema",
    "work_item_id",
    "app_id",
    "lifecycle_stage",
    "state",
    "claim",
    "proof_surface",
    "commands",
    "artifacts",
    "non_claims",
    "reviewer",
    "next_action"
  ],
  "properties": {
    "schema": {
      "const": "weave-proof-envelope/v0.1"
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "app_id": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_stage": {
      "$ref": "#/$defs/lifecycle_stage"
    },
    "state": {
      "type": "string",
      "enum": ["done", "blocked", "needs_owner_action", "revise", "accepted_for_scope"]
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "proof_surface": {
      "type": "string",
      "enum": [
        "SELF_REPORTED",
        "TOOL_VERIFIED_LOCAL",
        "TARGET_SURFACE_VERIFIED",
        "HUMAN_APPROVED",
        "EXTERNAL_SIDE_EFFECT",
        "SANITIZED_SUMMARY",
        "BLOCKED_PENDING_INPUT",
        "REVIEW_REQUIRED"
      ]
    },
    "commands": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "artifacts": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "non_claims": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "first_run",
        "owner_profile",
        "create_app",
        "intent",
        "research",
        "selection",
        "plan",
        "engineering",
        "qa",
        "deployment",
        "kpi",
        "marketing",
        "iteration",
        "analysis"
      ]
    },
    "non_empty_string_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
