{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/capability-grant.schema.json",
  "title": "WEAVE Capability Grant",
  "type": "object",
  "required": ["schema", "grant_id", "capability_id", "app_id", "stage", "status", "requested_by", "created_at", "allowed_actions", "forbidden_actions", "external_effect", "audit_required", "public_safe"],
  "properties": {
    "schema": {
      "const": "weave/capability-grant/v0.1"
    },
    "grant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.:-]*$"
    },
    "capability_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "stage": {
      "$ref": "#/$defs/stage"
    },
    "status": {
      "type": "string",
      "enum": ["requested", "active", "denied", "suspended", "revoked", "expired", "used", "failed"]
    },
    "requested_by": {
      "type": "string",
      "enum": ["owner", "agent", "weave-runtime", "system"]
    },
    "approved_by": {
      "type": "string",
      "enum": ["owner", "policy", "none"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "allowed_actions": {
      "$ref": "#/$defs/action_list"
    },
    "forbidden_actions": {
      "$ref": "#/$defs/action_list"
    },
    "approval_required_for": {
      "$ref": "#/$defs/action_list"
    },
    "external_effect": {
      "$ref": "#/$defs/external_effect"
    },
    "secret_ref": {
      "$ref": "#/$defs/secret_ref"
    },
    "evidence_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "audit_required": {
      "type": "boolean",
      "const": true
    },
    "public_safe": {
      "type": "boolean",
      "const": true
    },
    "claims": {
      "$ref": "#/$defs/string_list"
    },
    "non_claims": {
      "$ref": "#/$defs/string_list"
    }
  },
  "$defs": {
    "stage": {
      "type": "string",
      "enum": ["first_run", "owner_profile", "create_app", "intent", "research", "selection", "plan", "engineering", "qa", "deployment", "kpi", "marketing", "iteration", "analysis"]
    },
    "external_effect": {
      "type": "string",
      "enum": ["none", "read_only", "local_write", "staging_write", "production_write", "public_send", "paid_spend", "credential_scope_change", "destructive_change"]
    },
    "secret_ref": {
      "type": "string",
      "pattern": "^secret_ref:[a-z0-9][a-z0-9_.:-]*$"
    },
    "action_list": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      }
    },
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
