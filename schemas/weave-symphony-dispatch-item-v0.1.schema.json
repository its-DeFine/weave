{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/weave-symphony-dispatch-item-v0.1.schema.json",
  "title": "WEAVE Symphony Dispatch Item",
  "type": "object",
  "required": [
    "schema",
    "id",
    "identifier",
    "title",
    "description",
    "state",
    "labels",
    "branch_name",
    "url",
    "weave"
  ],
  "properties": {
    "schema": {
      "const": "weave-symphony-dispatch-item/v0.1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": ["queued", "running", "retrying", "blocked", "completed", "cancelled", "stale"]
    },
    "labels": {
      "$ref": "#/$defs/non_empty_string_list"
    },
    "branch_name": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "weave": {
      "type": "object",
      "required": ["app_id", "lifecycle_stage", "work_item_id", "proof_required", "non_claims"],
      "properties": {
        "app_id": {
          "type": "string",
          "minLength": 1
        },
        "lifecycle_stage": {
          "$ref": "#/$defs/lifecycle_stage"
        },
        "work_item_id": {
          "type": "string",
          "minLength": 1
        },
        "proof_required": {
          "$ref": "#/$defs/non_empty_string_list"
        },
        "non_claims": {
          "$ref": "#/$defs/non_empty_string_list"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "lifecycle_stage": {
      "type": "string",
      "enum": [
        "first_run",
        "owner_profile",
        "create_app",
        "intent",
        "research",
        "selection",
        "plan",
        "engineering",
        "qa",
        "deployment",
        "kpi",
        "marketing",
        "iteration",
        "analysis"
      ]
    },
    "non_empty_string_list": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
