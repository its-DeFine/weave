{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/event-ledger-entry.schema.json",
  "title": "WEAVE Event Ledger Entry",
  "type": "object",
  "required": ["schema", "event_id", "at", "app_id", "actor", "event_type", "summary", "public_safe"],
  "properties": {
    "schema": {
      "const": "weave/event-ledger-entry/v0.1"
    },
    "event_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "at": {
      "type": "string",
      "format": "date-time"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "stage": {
      "$ref": "#/$defs/stage"
    },
    "actor": {
      "type": "string",
      "enum": ["owner", "agent", "weave-runtime", "system", "external-adapter"]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "stage.entered",
        "stage.artifact_created",
        "stage.review_requested",
        "stage.revision_requested",
        "stage.approved",
        "stage.blocked",
        "decision.created",
        "decision.answered",
        "decision.deferred",
        "world_model.updated",
        "proof.recorded",
        "non_claim.recorded",
        "capability.requested",
        "capability.deferred",
        "job.created",
        "job.paused",
        "job.cancelled"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "artifact_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "decision_ref": {
      "type": "string"
    },
    "job_ref": {
      "type": "string"
    },
    "claims": {
      "$ref": "#/$defs/string_list"
    },
    "non_claims": {
      "$ref": "#/$defs/string_list"
    },
    "requires_owner_review": {
      "type": "boolean"
    },
    "public_safe": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "stage": {
      "type": "string",
      "enum": ["first_run", "owner_profile", "create_app", "intent", "research", "selection", "plan", "engineering", "qa", "deployment", "kpi", "marketing", "iteration", "analysis"]
    },
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
