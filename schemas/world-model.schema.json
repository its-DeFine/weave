{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/world-model.schema.json",
  "title": "WEAVE World Model",
  "type": "object",
  "required": ["schema", "app_id", "updated_at", "current_stage", "proof_boundary", "approval_boundaries"],
  "properties": {
    "schema": {
      "const": "weave/world-model/v0.1"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_stage": {
      "$ref": "#/$defs/stage"
    },
    "owner_preferences": {
      "type": "object",
      "additionalProperties": true
    },
    "selected_approach": {
      "type": "object",
      "properties": {
        "summary": {
          "type": "string"
        },
        "source_artifact_refs": {
          "$ref": "#/$defs/ref_list"
        }
      },
      "additionalProperties": true
    },
    "plans": {
      "type": "object",
      "properties": {
        "business": {
          "type": "string"
        },
        "engineering": {
          "type": "string"
        },
        "deployment": {
          "type": "string"
        },
        "qa": {
          "type": "string"
        },
        "kpi": {
          "type": "string"
        },
        "marketing": {
          "type": "string"
        },
        "iteration": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "deployment_state": {
      "type": "object",
      "additionalProperties": true
    },
    "kpi_definitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "definition": {
            "type": "string"
          },
          "proof_boundary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "marketing_state": {
      "type": "object",
      "additionalProperties": true
    },
    "active_jobs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["job_ref", "status"],
        "properties": {
          "job_ref": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "known_risks": {
      "$ref": "#/$defs/string_list"
    },
    "approval_boundaries": {
      "$ref": "#/$defs/string_list"
    },
    "capability_gaps": {
      "$ref": "#/$defs/string_list"
    },
    "proof_boundary": {
      "type": "object",
      "required": ["highest_proven_surface", "non_claims"],
      "properties": {
        "highest_proven_surface": {
          "type": "string",
          "enum": ["none", "spec_only", "local_deterministic", "local_runtime", "container_mesh", "live_transport", "deployed_staging", "deployed_production", "external_write_readback"]
        },
        "proof_refs": {
          "$ref": "#/$defs/ref_list"
        },
        "non_claims": {
          "$ref": "#/$defs/string_list"
        }
      },
      "additionalProperties": true
    },
    "claims": {
      "$ref": "#/$defs/string_list"
    },
    "non_claims": {
      "$ref": "#/$defs/string_list"
    }
  },
  "$defs": {
    "stage": {
      "type": "string",
      "enum": ["first_run", "owner_profile", "create_app", "intent", "research", "selection", "plan", "engineering", "qa", "deployment", "kpi", "marketing", "iteration", "analysis"]
    },
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
