{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/kill-switch.schema.json",
  "title": "WEAVE Kill Switch",
  "type": "object",
  "required": ["schema", "switch_id", "status", "created_at", "scope", "reason", "created_by", "public_safe"],
  "properties": {
    "schema": {
      "const": "weave/kill-switch/v0.1"
    },
    "switch_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.:-]*$"
    },
    "status": {
      "type": "string",
      "enum": ["enabled", "disabled", "expired", "superseded"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "scope": {
      "type": "object",
      "properties": {
        "app_ids": {
          "$ref": "#/$defs/ref_list"
        },
        "job_ids": {
          "$ref": "#/$defs/ref_list"
        },
        "job_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["marketing_engagement", "feedback_intake", "competitor_scan", "staged_implementation", "feature_recommendation", "analytics_review", "owner_followup", "capability_health_check"]
          }
        },
        "external_effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_effect"
          }
        },
        "capability_refs": {
          "$ref": "#/$defs/ref_list"
        }
      },
      "additionalProperties": true
    },
    "reason": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "enum": ["owner", "agent", "weave-runtime", "system"]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "public_safe": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "external_effect": {
      "type": "string",
      "enum": ["none", "read_only", "local_write", "staging_write", "production_write", "public_send", "paid_spend", "credential_scope_change", "destructive_change"]
    },
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
