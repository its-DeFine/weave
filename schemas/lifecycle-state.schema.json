{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/lifecycle-state.schema.json",
  "title": "WEAVE Lifecycle State",
  "type": "object",
  "required": ["schema", "app_id", "updated_at", "current_stage", "stage_source", "stages", "attention"],
  "properties": {
    "schema": {
      "const": "weave/lifecycle-state/v0.1"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "current_stage": {
      "$ref": "#/$defs/stage"
    },
    "stage_source": {
      "type": "string",
      "enum": ["derived", "event-ledger", "owner-approved", "agent-proposed", "system-imported"]
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["stage", "status"],
        "properties": {
          "stage": {
            "$ref": "#/$defs/stage"
          },
          "status": {
            "$ref": "#/$defs/stage_status"
          },
          "entered_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "artifact_refs": {
            "$ref": "#/$defs/ref_list"
          },
          "proof_refs": {
            "$ref": "#/$defs/ref_list"
          },
          "decision_refs": {
            "$ref": "#/$defs/ref_list"
          },
          "blockers": {
            "$ref": "#/$defs/string_list"
          },
          "claims": {
            "$ref": "#/$defs/string_list"
          },
          "non_claims": {
            "$ref": "#/$defs/string_list"
          }
        },
        "additionalProperties": true
      }
    },
    "attention": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": ["no_attention_needed", "agent_working", "owner_input_needed", "blocked_on_capability", "ready_for_review"]
        },
        "summary": {
          "type": "string"
        },
        "decision_refs": {
          "$ref": "#/$defs/ref_list"
        },
        "blocker_refs": {
          "$ref": "#/$defs/ref_list"
        }
      },
      "additionalProperties": true
    },
    "approval_boundaries": {
      "$ref": "#/$defs/string_list"
    },
    "capability_gaps": {
      "$ref": "#/$defs/string_list"
    },
    "active_job_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "claims": {
      "$ref": "#/$defs/string_list"
    },
    "non_claims": {
      "$ref": "#/$defs/string_list"
    }
  },
  "$defs": {
    "stage": {
      "type": "string",
      "enum": ["first_run", "owner_profile", "create_app", "intent", "research", "selection", "plan", "engineering", "qa", "deployment", "kpi", "marketing", "iteration", "analysis"]
    },
    "stage_status": {
      "type": "string",
      "enum": ["not_started", "collecting", "drafting", "review", "revision_requested", "approved", "running", "owner_input_needed", "blocked", "ready_for_review", "completed", "deferred"]
    },
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "string_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
