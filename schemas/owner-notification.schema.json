{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/owner-notification.schema.json",
  "title": "WEAVE Owner Notification",
  "type": "object",
  "required": ["schema", "notification_id", "app_id", "created_at", "source", "severity", "status", "title", "body", "public_safe"],
  "properties": {
    "schema": {
      "const": "weave/owner-notification/v0.1"
    },
    "notification_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.:-]*$"
    },
    "app_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": ["job", "lifecycle", "capability", "qa", "runtime", "system"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "review", "action_required", "blocked", "urgent"]
    },
    "status": {
      "type": "string",
      "enum": ["open", "acknowledged", "resolved", "dismissed", "expired"]
    },
    "title": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "action_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "evidence_refs": {
      "$ref": "#/$defs/ref_list"
    },
    "public_safe": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "ref_list": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": true
}
