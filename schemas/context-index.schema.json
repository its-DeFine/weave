{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.dev/schemas/context-index.schema.json",
  "title": "WEAVE Capability Context Index",
  "type": "object",
  "required": ["schema", "version", "updated_at", "sources"],
  "properties": {
    "schema": {
      "const": "weave/context-index/v0.1"
    },
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "publisher": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "url", "stage_use", "application_paths", "freshness", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "api",
              "sdk",
              "documentation",
              "example",
              "gateway",
              "pipeline",
              "capability-discovery",
              "pricing",
              "health",
              "orchestrator-capability",
              "container",
              "model",
              "hardware",
              "conformance-test",
              "operations",
              "kpi",
              "outreach"
            ]
          },
          "url": {
            "type": "string"
          },
          "primary": {
            "type": "boolean"
          },
          "stage_use": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["intent", "research", "selection", "plan", "engineering", "qa", "kpi", "marketing", "iteration", "analysis"]
            }
          },
          "application_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["existing_api", "gateway_capability", "new_orchestrator_capability"]
            }
          },
          "freshness": {
            "type": "string",
            "enum": ["stable_reference", "verify_before_use", "snapshot"]
          },
          "last_verified_at": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "credential_gate": {
            "type": "string"
          },
          "review_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
