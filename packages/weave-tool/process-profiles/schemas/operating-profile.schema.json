{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://weave.local/schemas/operating-profile.schema.json",
  "title": "WEAVE Operating Profile",
  "type": "object",
  "required": [
    "schema",
    "id",
    "name",
    "version",
    "trigger_mode",
    "authority_mode",
    "target_surface",
    "framework_stack",
    "required_artifacts",
    "hard_gates",
    "non_claims"
  ],
  "properties": {
    "schema": {
      "const": "weave-operating-profile/v0.1"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "trigger_mode": {
      "enum": ["reactive", "proactive", "hybrid"]
    },
    "authority_mode": {
      "enum": ["recommend_only", "bounded_local_action", "approval_required_action", "pre_authorized_external_action"]
    },
    "target_surface": {
      "type": "string",
      "minLength": 1
    },
    "private_data_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["real_private_data_allowed", "synthetic_private_data_allowed", "external_send_allowed"],
      "properties": {
        "real_private_data_allowed": {"type": "boolean"},
        "synthetic_private_data_allowed": {"type": "boolean"},
        "external_send_allowed": {"type": "boolean"}
      }
    },
    "framework_stack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "artifact"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1}
        }
      }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "hard_gates": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum_app_count": {"type": "integer", "minimum": 1},
        "parallel_default": {"type": "integer", "minimum": 1},
        "marketing_included": {"type": "boolean"},
        "iteration_mode": {"type": "string"}
      }
    }
  },
  "additionalProperties": false
}
