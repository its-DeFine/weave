{
  "schema": "weave-operating-profile/v0.2",
  "id": "private-app-parallel-assessment",
  "name": "Private App Parallel Assessment",
  "version": "2026.06.09",
  "trigger_mode": "reactive",
  "authority_mode": "recommend_only",
  "target_surface": "local deterministic private-app fixture with generated static apps and reviewable framework-gate evidence",
  "private_data_policy": {
    "real_private_data_allowed": false,
    "synthetic_private_data_allowed": true,
    "external_send_allowed": false
  },
  "proof_boundaries": {
    "highest_proven_surface": "local deterministic fixture/runtime-local proof",
    "not_proven": [
      "live Hermes-agent lifecycle",
      "Codex/Hermes goal-loop execution until acceptance",
      "Telegram/deployed-gateway adapter behavior",
      "hosted/private-app runtime behavior",
      "real private/customer data handling",
      "production/customer/market validation"
    ]
  },
  "framework_stack": [
    {
      "id": "cwa_discovery",
      "role": "model private-domain actors, constraints, values, functions, required information, and missing blockers before building",
      "artifact": "cwa-work-domain.json"
    },
    {
      "id": "dmn_decision_table",
      "role": "route authority, privacy, marketing exclusion, local-only action, and proof-boundary decisions deterministically",
      "artifact": "dmn-routing-table.json"
    },
    {
      "id": "ibis_issue_map",
      "role": "record contested product-shape options and block unwaived unresolved issues",
      "artifact": "ibis-issue-map.json"
    },
    {
      "id": "adr_decision_record",
      "role": "commit meaningful implementation decisions and consequences before engineering completion",
      "artifact": "adr-0001-local-private-first.md"
    },
    {
      "id": "premortem_review",
      "role": "classify likely failure modes as blocker, test, deferred, owner-gated, or accepted non-goal",
      "artifact": "premortem-report.json"
    },
    {
      "id": "prov_ledger",
      "role": "prove who/what produced each artifact, transition, verification, and proof-boundary claim",
      "artifact": "prov-ledger.jsonl"
    }
  ],
  "optional_frameworks": [
    {
      "id": "gestalt",
      "status": "deferred_by_default",
      "reason": "Owner feedback: Gestalt artifacts are confusing for this test unless explicitly enabled.",
      "enable_when": [
        "owner requests whole-system contract",
        "cross-product coherence is the primary risk",
        "handoff requires whole-experience traceability"
      ],
      "artifacts_if_enabled": [
        "gestalt-kernel.json",
        "gestaltian-contract.json",
        "traceability-map.json"
      ],
      "gate_if_enabled": "handoff and QA must cite traceability-map.json"
    }
  ],
  "required_artifacts": [
    "intent-frame.json",
    "profile-selection.json",
    "intake-state.json",
    "cwa-work-domain.json",
    "information-requirements.json",
    "missing-information-assessment.json",
    "dmn-routing-table.json",
    "decision-evaluation-log.json",
    "ibis-issue-map.json",
    "open-issues.json",
    "adr-0001-local-private-first.md",
    "decision-register.json",
    "premortem-report.json",
    "risk-to-test-map.json",
    "action-intent.json",
    "action-result.json",
    "proof-boundary-report.json",
    "lifecycle-transition-log.jsonl",
    "prov-ledger.jsonl",
    "assessment-report.json",
    "review.json",
    "aggregate-review.json"
  ],
  "hard_gates": [
    {
      "id": "cwa_missing_information_gate",
      "framework": "cwa_discovery",
      "rule": "if missing-information-assessment has required_missing items, transition must be clarify_or_pause, not engineering_execution",
      "consumes": ["missing-information-assessment.json"],
      "controls": ["engineering_execution"]
    },
    {
      "id": "dmn_transition_gate",
      "framework": "dmn_decision_table",
      "rule": "every lifecycle transition must cite a decision rule id or owner override id",
      "consumes": ["dmn-routing-table.json", "decision-evaluation-log.json", "lifecycle-transition-log.jsonl"],
      "controls": ["all_transitions"]
    },
    {
      "id": "ibis_blocker_gate",
      "framework": "ibis_issue_map",
      "rule": "open blocking issues must be resolved, waived by owner, or pause lifecycle",
      "consumes": ["ibis-issue-map.json", "open-issues.json"],
      "controls": ["handoff_ready"]
    },
    {
      "id": "adr_decision_gate",
      "framework": "adr_decision_record",
      "rule": "meaningful implementation choices must have a decision-register or ADR entry before engineering completion",
      "consumes": ["adr-0001-local-private-first.md", "decision-register.json"],
      "controls": ["engineering_completion"]
    },
    {
      "id": "premortem_risk_gate",
      "framework": "premortem_review",
      "rule": "major foreseeable risks must map to tests, blockers, deferrals, owner gates, or accepted non-goals",
      "consumes": ["premortem-report.json", "risk-to-test-map.json"],
      "controls": ["qa_verification"]
    },
    {
      "id": "prov_claim_gate",
      "framework": "prov_ledger",
      "rule": "no proof claim may be emitted unless supported by provenance and transition ledger events",
      "consumes": ["prov-ledger.jsonl", "proof-boundary-report.json"],
      "controls": ["proof_report"]
    }
  ],
  "company_process": {
    "case_type": "private_app_build_assessment",
    "roles": [
      {"id": "operator", "owns": ["case_state", "stage_transitions", "proof_boundary"]},
      {"id": "product_planning", "owns": ["requirements", "information_sufficiency", "handoff"]},
      {"id": "engineering", "owns": ["local_artifact_build", "bounded_execution"]},
      {"id": "qa", "owns": ["functional_checks", "framework_gate_checks", "claim_limits"]},
      {"id": "owner_manual_feedback", "owns": ["missing_required_information", "waivers", "approval"]}
    ],
    "lifecycle_states": [
      {"id": "input_normalization", "owner_role": "operator", "produces": ["intake-state.json"], "exit_gate": "intake_state_complete_or_missing_info_classified"},
      {"id": "cwa_information_assessment", "owner_role": "product_planning", "produces": ["cwa-work-domain.json", "information-requirements.json", "missing-information-assessment.json"], "exit_gate": "cwa_missing_information_gate"},
      {"id": "dmn_routing", "owner_role": "operator", "produces": ["dmn-routing-table.json", "decision-evaluation-log.json"], "exit_gate": "dmn_transition_gate"},
      {"id": "ibis_premortem_handoff", "owner_role": "product_planning", "produces": ["ibis-issue-map.json", "open-issues.json", "premortem-report.json", "risk-to-test-map.json"], "exit_gate": "ibis_blocker_gate"},
      {"id": "engineering_execution", "owner_role": "engineering", "entry_gate": "handoff_ready", "produces": ["action-intent.json", "action-result.json"]},
      {"id": "qa_verification", "owner_role": "qa", "produces": ["assessment-report.json", "review.json"], "exit_gate": "all_required_checks_pass_or_pause"},
      {"id": "proof_report", "owner_role": "operator", "produces": ["proof-boundary-report.json", "aggregate-review.json"], "exit_gate": "prov_claim_gate"}
    ],
    "escalation": {
      "default_unresolved_attempt_limit": 3,
      "on_limit_reached": "pause_for_owner_manual_feedback"
    }
  },
  "non_claims": [
    "not live Hermes CLI proof",
    "not Telegram or deployed gateway proof",
    "not hosted application proof",
    "not marketing, analytics, payment, or real-user traction proof",
    "not proof over real private customer data"
  ],
  "evaluation": {
    "minimum_app_count": 10,
    "parallel_default": 4,
    "marketing_included": false,
    "iteration_mode": "private recommendation artifacts only"
  }
}
